ANTHROPIC_API_KEY=sk-ant-...

# Alpaca real-time quotes (free IEX feed) — Trader Desk live prices
ALPACA_KEY=
ALPACA_SECRET=

# Databento historical futures (GC, ES, NQ, etc.) — CME Globex MDP3
DATABENTO_API_KEY=db-...

# Order-flow engine: feed CME futures bars from Databento.
# Symbols accept either raw contracts (GCM6) or parent tokens (ES.FUT,
# GC.FUT) which auto-resolve to the most-active front-month at startup.
# Multi-symbol via OF_DATABENTO_SYMBOLS (comma-separated). Each spawns
# its own poll thread + tail bucket.
OF_DATABENTO_ENABLED=0
OF_DATABENTO_SYMBOL=ES.FUT
OF_DATABENTO_SYMBOLS=ES.FUT,GC.FUT
OF_DATABENTO_TF=1m
# Comma-separated TF list — each (symbol, tf) gets its own thread + tail.
# Include the engine anchor TF (default 15m) so rules fire on closed bars.
OF_DATABENTO_TFS=1m,15m
# Pull `trades` schema and tick-rule classify aggressor side → real
# buy_vol/sell_vol per bar (lifts engine out of proxy_mode). Adds Databento
# bandwidth — only enable when bandwidth/cost is acceptable.
OF_DATABENTO_REAL_FLOW=0

# Equities OHLCV: "databento" routes daily bars through EQUS.MINI (fast,
# consistent, but only ~3yr history). Anything else stays on yfinance.
EQUITIES_SOURCE=yfinance
