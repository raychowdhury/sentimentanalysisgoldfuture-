    def _live_signal_details(symbol: str, tf: str) -> list[dict]:
        """Read-only: derive entry/stop/target/MFE/MAE prices for live-only
        R1/R2 + R7 shadow signals from existing outcome JSONLs/pending JSONs.
        Does NOT mutate any engine state. Stop = 1*ATR opposite to direction;
        target = 1*ATR with direction. MFE/MAE prices use fwd_high/fwd_low
        depending on direction."""

        out_path     = of_cfg.OF_OUTPUT_DIR / f"realflow_outcomes_{symbol}_{tf}.jsonl"
        pend_path    = of_cfg.OF_OUTPUT_DIR / f"realflow_outcomes_pending_{symbol}_{tf}.json"
        sh_path      = of_cfg.OF_OUTPUT_DIR / f"realflow_r7_shadow_outcomes_{symbol}_{tf}.jsonl"
        sh_pend_path = of_cfg.OF_OUTPUT_DIR / f"realflow_r7_shadow_pending_{symbol}_{tf}.json"

        def derive(r: dict, status: str) -> dict | None:
            e = r.get("entry_close")
            d = r.get("direction") or 0
            atr = r.get("atr") or 0.0
            if e is None or atr <= 0:
                return None
            stop   = e - d * atr
            target = e + d * atr
            mfe_price = mae_price = None
            if status == "settled":
                hi = r.get("fwd_high_at_horizon")
                lo = r.get("fwd_low_at_horizon")
                if d > 0:
                    mfe_price, mae_price = hi, lo
                else:
                    mfe_price, mae_price = lo, hi
            return {
                "rule":       r.get("rule"),
                "fire_ts_ny": r.get("fire_ts_ny"),
                "session":    r.get("session"),
                "direction":  "long" if d > 0 else ("short" if d < 0 else "?"),
                "entry":      round(float(e), 4),
                "stop":       round(float(stop), 4),
                "target":     round(float(target), 4),
                "mfe_price":  round(float(mfe_price), 4) if mfe_price is not None else None,
                "mae_price":  round(float(mae_price), 4) if mae_price is not None else None,
                "final_r":    round(float(r.get("fwd_r_signed")), 3)
                              if status == "settled" and r.get("fwd_r_signed") is not None else None,
                "outcome":    r.get("outcome", "PENDING") if status == "settled" else "PENDING",
                "status":     status,
            }

        def load_jsonl(p: Path) -> list[dict]:
            if not p.exists():
                return []
            items: list[dict] = []
            with p.open() as f:
                for line in f:
                    line = line.strip()
                    if not line:
                        continue
                    try:
                        items.append(json.loads(line))
                    except Exception:
                        continue
            return items

        def load_json(p: Path) -> list[dict]:
            if not p.exists():
                return []
            try:
                data = json.loads(p.read_text())
                return data if isinstance(data, list) else []
            except Exception:
                return []

        rows: list[dict] = []
        for r in load_jsonl(out_path):
            if r.get("mode") == "live":
                row = derive(r, "settled")
                if row:
                    rows.append(row)
        for r in load_json(pend_path):
            if r.get("mode") == "live":
                row = derive(r, "pending")
                if row:
                    rows.append(row)
        for r in load_jsonl(sh_path):
            if r.get("mode") == "live":
                row = derive(r, "settled")
                if row:
                    rows.append(row)
        for r in load_json(sh_pend_path):
            if r.get("mode") == "live":
                row = derive(r, "pending")
                if row:
                    rows.append(row)
        rows.sort(key=lambda x: x.get("fire_ts_ny") or "")
        return rows

    def _trader_summary(symbol: str, tf: str,
                        outcomes: dict | None,
                        r7_shadow: dict | None) -> dict:
        """Compute Trader View Layer-1 summary fields. Read-only — no
        mutation. Inputs: existing health-monitor state, outcomes summary,
        r7_shadow summary, raw outcomes JSONL for per-rule live stats."""
        import pandas as pd  # noqa: F401
        from datetime import datetime, timezone

        health_state_path = of_cfg.OF_OUTPUT_DIR / ".health_state.json"
        health: dict = {}
        if health_state_path.exists():
            try:
                health = json.loads(health_state_path.read_text())
            except Exception:
                health = {}

        def is_unhealthy(name: str) -> bool:
            return health.get(name) == "unhealthy"

        now = datetime.now(timezone.utc)
        wd, hr = now.weekday(), now.hour
        market_closed = (wd == 5) or (wd == 6 and hr < 22) or (wd == 4 and hr >= 22)

        critical_down = (is_unhealthy("s1_flask_proc")
                         or is_unhealthy("s6_raw_freshness")
                         or is_unhealthy("s7_monitor_loop_proc"))
        unhealthy_n = sum(1 for v in health.values() if v == "unhealthy")
        if critical_down or unhealthy_n >= 3:
            system = "Broken"
        elif unhealthy_n > 0:
            system = "Warning"
        else:
            system = "Healthy"

        if market_closed:
            live_data = "Closed"
        else:
            s3_ok = not is_unhealthy("s3_live_sdk_stream")
            s4_ok = not is_unhealthy("s4_live_1m_freshness")
            if s3_ok and s4_ok:
                live_data = "Connected"
            elif s3_ok or s4_ok:
                live_data = "Slow"
            else:
                live_data = "Stale"

        out_path = of_cfg.OF_OUTPUT_DIR / f"realflow_outcomes_{symbol}_{tf}.jsonl"
        r1_live = {"n": 0, "wins": 0, "rs": []}
        r2_live = {"n": 0, "wins": 0, "rs": []}
        if out_path.exists():
            try:
                with out_path.open() as f:
                    for line in f:
                        line = line.strip()
                        if not line:
                            continue
                        try:
                            r = json.loads(line)
                        except Exception:
                            continue
                        if r.get("mode") != "live":
                            continue
                        if r.get("rule") == "r1_buyer_down":
                            bucket = r1_live
                        elif r.get("rule") == "r2_seller_up":
                            bucket = r2_live
                        else:
                            continue
                        bucket["n"] += 1
                        if r.get("outcome") == "win":
                            bucket["wins"] += 1
                        fr = r.get("fwd_r_signed")
                        if fr is not None:
                            bucket["rs"].append(fr)
            except Exception:
                pass

        BL = {"r1_buyer_down": 1.18, "r2_seller_up": 0.75}

        def classify(stats: dict, baseline: float) -> str:
            n = stats["n"]
            if n == 0:
                return "Watching"
            mean_r = sum(stats["rs"]) / len(stats["rs"]) if stats["rs"] else 0.0
            retention = (mean_r / baseline) if baseline else 0.0
            hit_rate = stats["wins"] / n
            if n >= 30 and retention >= 0.8 and hit_rate >= 0.55:
                return "Strong"
            if n >= 10 and (retention < 0.5 or mean_r <= 0):
                return "Weak"
            return "Watching"

        r1_status = classify(r1_live, BL["r1_buyer_down"])
        r2_status = classify(r2_live, BL["r2_seller_up"])

        r7_live_n = 0
        if r7_shadow:
            bm = r7_shadow.get("by_mode", {}) or {}
            live_block = bm.get("live", {}) or {}
            r7_live_n = live_block.get("n", 0) or 0
        r7_status = "Research" if r7_live_n >= 30 else "Shadow only"

        pending_n = 0
        for p in (
            of_cfg.OF_OUTPUT_DIR / f"realflow_outcomes_pending_{symbol}_{tf}.json",
            of_cfg.OF_OUTPUT_DIR / f"realflow_r7_shadow_pending_{symbol}_{tf}.json",
        ):
            if p.exists():
                try:
                    d = json.loads(p.read_text())
                    if isinstance(d, list):
                        pending_n += len(d)
                except Exception:
                    pass

        if system == "Broken" or live_data == "Stale":
            action = "Stop using signal"
        elif r1_status == "Weak" or r2_status == "Weak" or pending_n > 30:
            action = "Investigate"
        else:
            action = "Keep monitoring"

        live_1m = of_cfg.OF_PROCESSED_DIR / f"{symbol}_1m_live.parquet"
        freshness_label = "—"
        if live_1m.exists():
            try:
                df = pd.read_parquet(live_1m)
                df.index = pd.to_datetime(df.index)
                if df.index.tz is None:
                    df.index = df.index.tz_localize("UTC")
                age_min = (now - df.index.max().to_pydatetime()).total_seconds() / 60
                freshness_label = f"{age_min:.1f} min"
            except Exception:
                pass

        live_trades_n = r1_live["n"] + r2_live["n"]

        needed = max(0, 30 - min(r1_live["n"], r2_live["n"]))
        if needed == 0:
            eta_label = "GATE 8 CLEARED"
        else:
            days = needed / 3.3
            eta_label = f"~{days:.1f}d (need {needed})"

        return {
            "system":        system,
            "live_data":     live_data,
            "r1":            r1_status,
            "r2":            r2_status,
            "r7":            r7_status,
            "action":        action,
            "freshness":     freshness_label,
            "live_trades_n": live_trades_n,
            "eta_to_gate":   eta_label,
            "r1_live_n":     r1_live["n"],
            "r2_live_n":     r2_live["n"],
            "r7_live_n":     r7_live_n,
            "pending_n":     pending_n,
        }

