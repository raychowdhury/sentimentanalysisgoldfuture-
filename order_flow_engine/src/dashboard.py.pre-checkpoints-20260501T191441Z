        return of_cfg.OF_OUTPUT_DIR / f"realflow_r7_shadow_outcomes_{symbol}_{tf}.jsonl"

    def _read_jsonl_tail(path: Path, n: int) -> list[dict]:
        if not path.exists():
            return []
        rows: list[dict] = []
        with path.open() as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    rows.append(json.loads(line))
                except Exception:
                    continue
        return rows[-n:]

