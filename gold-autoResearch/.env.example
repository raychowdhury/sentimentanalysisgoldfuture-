# Copy to .env and fill in. docker-compose reads from .env automatically.

# Anthropic API key for meta_optimizer (Claude calls).
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# FRED API key — optional; the public CSV endpoint works without one.
FRED_API_KEY=your-fred-key-or-leave-blank

# Postgres connection string used by the autoresearch service and any
# downstream SaaS services that read the run history.
DATABASE_URL=postgresql://autoresearch:autoresearch@postgres:5432/autoresearch

# Claude model used by meta_optimizer. Override if you want a newer Sonnet/Opus.
CLAUDE_MODEL=claude-sonnet-4-20250514

# Optional overrides for the research loop.
LOOP_INTERVAL_HOURS=24
META_OPTIMIZE_EVERY=10
